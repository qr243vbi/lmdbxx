#!/bin/bash
set -e

echo "Testing lmdbxx installation..."

headers=(
    "/usr/include/lmdb++.h"
    "/usr/include/lmdbxx/lmdb++.h"
)

pkgconfig="/usr/lib/pkgconfig/lmdbxx.pc"

failed=0

for header in "${headers[@]}"; do
    if [ -f "$header" ]; then
        echo "✓ Found: $header"
    else
        echo "✗ Missing: $header"
        failed=1
    fi
done

if [ -f "$pkgconfig" ]; then
    echo "✓ Found: $pkgconfig"
else
    echo "✗ Missing: $pkgconfig"
    failed=1
fi

if [ $failed -eq 0 ]; then
    echo "✓ All required files installed"
    exit 0
else
    echo "✗ Installation test failed"
    exit 1
fi